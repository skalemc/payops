{
  "name": "payops-server",
  "version": "1.0.0",
  "description": "PayOps payroll platform — Express API server",
  "main": "index.js",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev":     "node --watch --env-file=.env index.js",
    "start":   "node index.js",
    "migrate": "node scripts/migrate.js",
    "seed":    "node scripts/seed.js",
    "test":    "node --test"
  },
  "dependencies": {
    "express":            "^4.19.2",
    "pg":                 "^8.12.0",
    "bcryptjs":           "^2.4.3",
    "jsonwebtoken":       "^9.0.2",
    "zod":                "^3.23.8",
    "nodemailer":         "^6.9.14",
    "multer":             "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.600.0",
    "helmet":             "^7.1.0",
    "cors":               "^2.8.5",
    "express-rate-limit": "^7.4.0",
    "morgan":             "^1.10.0",
    "dotenv":             "^16.4.5",
    "uuid":               "^10.0.0",
    "dayjs":              "^1.11.12"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
